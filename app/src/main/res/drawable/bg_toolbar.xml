<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#03060E"
                android:endColor="#040C1E" />
        </shape>
    </item>
    <!-- Gold bottom border -->
    <item android:top="-4dp" android:left="-4dp" android:right="-4dp">
        <shape>
            <stroke android:width="1dp" android:color="#44FFD700" />
        </shape>
    </item>
</layer-list>
