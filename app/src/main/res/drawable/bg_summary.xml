<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#04081A"
                android:centerColor="#05143C"
                android:endColor="#04081A" />
        </shape>
    </item>
    <!-- Gold top border -->
    <item android:bottom="-4dp" android:left="-4dp" android:right="-4dp">
        <shape>
            <stroke android:width="1dp" android:color="#55FFD700" />
        </shape>
    </item>
</layer-list>
